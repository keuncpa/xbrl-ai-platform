    {
      "parent": "ifrs-full:Assets",
      "children": [
        "ifrs-full:CurrentAssets",
        "ifrs-full:NoncurrentAssets"
      ],
      "operation": "sum"
    },
    {
      "parent": "ifrs-full:Liabilities",
      "children": [
        "ifrs-full:CurrentLiabilities",
        "ifrs-full:NoncurrentLiabilities"
      ],
      "operation": "sum"
    },
    {
      "parent": "ifrs-full:Equity",
      "children": [
        "ifrs-full:EquityAttributableToOwnersOfParent",
        "ifrs-full:NoncontrollingInterests"
      ],
      "operation": "sum"
    },
    {
      "parent": "ifrs-full:GrossProfit",
      "children": [
        "ifrs-full:Revenue"
      ],
      "subtract": [
        "ifrs-full:CostOfSales"
      ],
      "operation": "subtract"
    },
    {
      "parent": "ifrs-full:ProfitLoss",
      "children": [
        "ifrs-full:ProfitBeforeTax"
      ],
      "subtract": [
        "ifrs-full:IncomeTaxExpenseContinuingOperations"
      ],
      "operation": "subtract"
    }
  ],
  "balance_sheet_equation": {
    "description": "자산총계 = 부채총계 + 자본총계, 또는 부채와자본총계 = 자산총계",
    "equation_1": {
      "left": "ifrs-full:Assets",
      "right": [
        "ifrs-full:Liabilities",
        "ifrs-full:Equity"
      ]
    },
    "equation_2": {
      "left": "ifrs-full:LiabilitiesAndEquity",
      "right": [
        "ifrs-full:Assets"
      ]
    }
  }
